{
    // Utilisez IntelliSense pour en savoir plus sur les attributs possibles.
    // Pointez pour afficher la description des attributs existants.
    // Pour plus d'informations, visitez : https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Lancer Chrome en utilisant localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}",
            "runtimeArgs": [
                "--auto-open-devtools-for-tabs"
            ]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome (port 5500 / Live Server)",
            "url": "http://localhost:5500",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "chrome",
            "request": "attach",
            "name": "Attacher à Chrome (port 9222)",
            "address": "localhost",
            "port": 9222,
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "pwa-msedge",
            "request": "launch",
            "name": "Edge (InPrivate – localhost 8080)",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}",
            "runtimeArgs": [
                "--inprivate"
            ]
        },
        {
            "type": "firefox",
            "request": "launch",
            "name": "Firefox (localhost 8080)",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}",
            "reAttach": true
        }
    ],
    "compounds": [
        {
            "name": "Comparer Chrome / Edge",
            "configurations": [
                "Lancer Chrome en utilisant localhost",
                "Edge (InPrivate – localhost 8080)"
            ]
        }
    ]
}
